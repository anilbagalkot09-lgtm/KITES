{
  "canvasSpec": {
    "component_id": "kites-investor-showcase",
    "type": "web_app",
    "title": "KITES - Production Grade Investor Showcase Website",
    "description": "An interactive investor-ready showcase website built for KITES (Kalika Induction Tech Equipments & Solutions) featuring real-time ROI simulation, high-demand kitchen telemetry models, and an enterprise product catalog layout.",
    "code_files": [
      {
        "name": "App.jsx",
        "content": "import React, { useState } from 'react';\nimport {\n  Flame,\n  Zap,\n  Gauge,\n  Layers,\n  ShieldCheck,\n  TrendingUp,\n  DollarSign,\n  Cpu,\n  Mail,\n  Phone,\n  MapPin,\n  ChevronRight,\n  Activity,\n  Thermometer,\n  Clock\n} from 'lucide-react';\n\n// --- COMPONENTIZED DATA MOCKS FROM BROCHURE ---\nconst PRODUCTS = [\n  {\n    id: 'multi-zone',\n    name: 'Multi-Zone Cooking Solutions',\n    category: 'Commercial Kitchen',\n    description: 'Flexible systems allowing simultaneous preparation across multiple zones with absolute precision control.',\n    specs: { power: '8-12 kW', size: '3\\' x 5\\' x 2.5\\'', weight: '50-60 kg', capacity: '2 Dish / 2 Zone' }\n  },\n  {\n    id: 'chinese-wok',\n    name: '2 Zone Chinese Wok',\n    category: 'Specialized Systems',\n    description: 'High-power targeted heating tailored for fast-paced wok stations requiring instant heat manipulation.',\n    specs: { power: '3-5 kW', size: '2\\' x 4\\' x 2.5\\'', weight: '30-40 kg', capacity: '2 Dish' }\n  },\n  {\n    id: 'dosa-tawa',\n    name: '2x2 Dosa Tawa System',\n    category: 'Sleek Live Counter',\n    description: 'Uniform surface temperature profile engineered for high-throughput, consistent live counter execution.',\n    specs: { power: '5-40 kW', size: 'Multiple Options', weight: '50-150 kg', capacity: 'High Volume' }\n  },\n  {\n    id: 'bulk-bret-pan',\n    name: 'Industrial Bret Pan',\n    category: 'Bulk Cooking Units',\n    description: 'High-capacity smart induction container engineered for structural endurance and continuous preparation.',\n    specs: { power: '8-40 kW', size: 'Multiple Options', weight: 'Varying Scale', capacity: '100L - 500L' }\n  },\n  {\n    id: 'continuous-roaster',\n    name: 'Continuous Industrial Roaster',\n    category: 'Specialized Induction',\n    description: 'Industry 4.0-ready continuous processing unit optimized for consistent output and automated telemetry.',\n    specs: { power: '60-120 kW', size: 'Heavy Manufacturing Scale', weight: 'Varying Scale', capacity: '5\\' to 10\\' Feed' }\n  },\n  {\n    id: 'milk-boiler',\n    name: 'Precision Milk Boiler',\n    category: 'Bulk Cooking Units',\n    description: 'Anti-spill thermal curve logic configured to heat large volume vessels safely without localized boiling scalds.',\n    specs: { power: '8-30 kW', size: 'Multiple Options', weight: 'Varying Scale', capacity: '25L - 500L' }\n  }\n];\n\nexport default function App() {\n  const [activeTab, setActiveTab] = useState('overview');\n  const [selectedProduct, setSelectedProduct] = useState(PRODUCTS[0]);\n  \n  // Interactive State for the Pitch Value Proposition\n  const [operatingHours, setOperatingHours] = useState(12);\n  const [gasStoveCount, setGasStoveCount] = useState(4);\n\n  // Simulated ROI Matrix based on KITES 90% thermal efficiency vs gas 40% efficiency\n  const baselineGasCostPerMonth = gasStoveCount * operatingHours * 135; // Mock currency operational baseline units\n  const kitesElectricCostPerMonth = (baselineGasCostPerMonth * 0.42); // Representing the dramatic efficiency gain\n  const dynamicMonthlySavings = Math.round(baselineGasCostPerMonth - kitesElectricCostPerMonth);\n  const carbonReductionKg = Math.round(gasStoveCount * operatingHours * 2.8 * 30);\n\n  return (\n    <div className=\"min-h-screen bg-slate-950 text-slate-100 font-sans selection:bg-cyan-500 selection:text-slate-900\">\n      \n      {/* --- ENTERPRISE TOP HEADER BAR --- */}\n      <header className=\"sticky top-0 z-50 backdrop-blur-md bg-slate-950/80 border-b border-slate-800\">\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"relative p-2 bg-gradient-to-br from-cyan-500 to-blue-600 rounded-lg shadow-lg shadow-cyan-500/20\">\n              <Zap className=\"w-6 h-6 text-slate-900 stroke-[2.5]\" />\n              <span className=\"absolute -bottom-1 -right-1 flex h-2 w-2\">\n                <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75\"></span>\n                <span className=\"relative inline-flex rounded-full h-2 w-2 bg-emerald-500\"></span>\n              </span>\n            </div>\n            <div>\n              <div className=\"flex items-baseline gap-1.5\">\n                <span className=\"text-2xl font-black tracking-tight text-white\">KITES</span>\n                <span className=\"text-xs font-semibold px-1.5 py-0.5 bg-slate-800 rounded text-cyan-400 border border-slate-700\">SERIES 4.0</span>\n              </div>\n              <p className=\"text-[10px] text-slate-400 font-mono tracking-widest uppercase\">Kalika Induction Tech</p>\n            </div>\n          </div>\n\n          <nav className=\"hidden md:flex items-center gap-1 bg-slate-900 p-1.5 rounded-xl border border-slate-800\">\n            <button \n              onClick={() => setActiveTab('overview')} \n              className={`px-4 py-2 rounded-lg text-sm font-medium transition-all ${activeTab === 'overview' ? 'bg-cyan-500 text-slate-950 shadow-md font-semibold' : 'text-slate-400 hover:text-slate-200'}`}\n            >\n              Market Pitch\n            </button>\n            <button \n              onClick={() => setActiveTab('sim')} \n              className={`px-4 py-2 rounded-lg text-sm font-medium transition-all ${activeTab === 'sim' ? 'bg-cyan-500 text-slate-950 shadow-md font-semibold' : 'text-slate-400 hover:text-slate-200'}`}\n            >\n              Efficiency Lab\n            </button>\n            <button \n              onClick={() => setActiveTab('hardware')} \n              className={`px-4 py-2 rounded-lg text-sm font-medium transition-all ${activeTab === 'hardware' ? 'bg-cyan-500 text-slate-950 shadow-md font-semibold' : 'text-slate-400 hover:text-slate-200'}`}\n            >\n              Product Ecosystem\n            </button>\n          </nav>\n\n          <div>\n            <span className=\"inline-flex items-center gap-2 px-4 py-2 rounded-xl text-xs font-mono font-bold tracking-wider uppercase border border-emerald-500/30 bg-emerald-950/20 text-emerald-400\">\n              <ShieldCheck className=\"w-4 h-4\" /> SECURE DEMO MODE\n            </span>\n          </div>\n        </div>\n      </header>\n\n      {/* --- DEEP INTERACTIVE BODY LAYOUT --- */}\n      <main className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10\">\n        \n        {/* VIEW ONE: DEEP TECH INVESTOR OVERVIEW */}\n        {activeTab === 'overview' && (\n          <div className=\"space-y-16 animate-fadeIn\">\n            {/* HERO SECTION */}\n            <div className=\"relative rounded-3xl bg-gradient-to-b from-slate-900 to-slate-950 p-8 md:p-12 border border-slate-800 overflow-hidden shadow-2xl\">\n              <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(6,182,212,0.08),transparent_50%)]\" />\n              \n              <div className=\"relative max-w-3xl space-y-6\">\n                <div className=\"inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium bg-cyan-950/40 text-cyan-400 border border-cyan-800/50\">\n                  <Cpu className=\"w-3.5 h-3.5 animate-spin-slow\" /> Hardware-as-a-Service & CleanTech Dynamic Model\n                </div>\n                <h1 className=\"text-4xl md:text-6xl font-black tracking-tight text-white leading-tight\">\n                  Heat Only <br className=\"hidden sm:inline\" />\n                  <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-blue-400 to-indigo-400\">\n                    What Matters.\n                  </span>\n                </h1>\n                <p className=\"text-lg text-slate-300 leading-relaxed\">\n                  Redefining modern commercial heating infrastructure. KITES engineers precision-coiled, high-performance induction modules built to transition high-demand enterprise food systems and manufacturing platforms into modular, Industry 4.0 telemetry grids.\n                </p>\n                <div className=\"pt-4 flex flex-wrap gap-4\">\n                  <button \n                    onClick={() => setActiveTab('sim')} \n                    className=\"px-6 py-3.5 rounded-xl font-semibold bg-gradient-to-r from-cyan-500 to-blue-600 text-slate-950 hover:from-cyan-400 hover:to-blue-500 transition-all flex items-center gap-2 shadow-lg shadow-cyan-500/20 group\"\n                  >\n                    Simulate Operational ROI \n                    <ChevronRight className=\"w-4 h-4 transition-transform group-hover:translate-x-1\" />\n                  </button>\n                  <button \n                    onClick={() => setActiveTab('hardware')}\n                    className=\"px-6 py-3.5 rounded-xl font-semibold bg-slate-900 text-slate-200 border border-slate-700 hover:bg-slate-800 transition-all\"\n                  >\n                    Explore Hardware Portfolio\n                  </button>\n                </div>\n              </div>\n            </div>\n\n            {/* CORE VALUE PILLARS FROM BROCHURE */}\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n              <div className=\"bg-slate-900/50 p-6 rounded-2xl border border-slate-800/80 hover:border-slate-700/80 transition-all\">\n                <div className=\"p-3 bg-cyan-950/50 rounded-xl text-cyan-400 w-fit mb-4 border border-cyan-800/30\">\n                  <Gauge className=\"w-6 h-6\" />\n                </div>\n                <h3 className=\"text-lg font-bold text-white mb-2\">Engineered Efficiency</h3>\n                <p className=\"text-sm text-slate-400 leading-relaxed\">\n                  Every multi-layer layout coil configuration is optimized to maximize localized electromagnetic conversion, drastically cutting standard ambient heat losses encountered via fossil fuels.\n                </p>\n              </div>\n\n              <div className=\"bg-slate-900/50 p-6 rounded-2xl border border-slate-800/80 hover:border-slate-700/80 transition-all\">\n                <div className=\"p-3 bg-blue-950/50 rounded-xl text-blue-400 w-fit mb-4 border border-blue-800/30\">\n                  <Layers className=\"w-6 h-6\" />\n                </div>\n                <h3 className=\"text-lg font-bold text-white mb-2\">Adaptive Flexibility</h3>\n                <p className=\"text-sm text-slate-400 leading-relaxed\">\n                  Custom structural variants built for real-world heavy workloads, encompassing compact live-cooking multi-zone panels to 500-liter high-duty deep batch systems.\n                </p>\n              </div>\n\n              <div className=\"bg-slate-900/50 p-6 rounded-2xl border border-slate-800/80 hover:border-slate-700/80 transition-all\">\n                <div className=\"p-3 bg-indigo-950/50 rounded-xl text-indigo-400 w-fit mb-4 border border-indigo-800/30\">\n                  <Activity className=\"w-6 h-6\" />\n                </div>\n                <h3 className=\"text-lg font-bold text-white mb-2\">Industry 4.0 Connected</h3>\n                <p className=\"text-sm text-slate-400 leading-relaxed\">\n                  Prepared for complex multi-facility diagnostic tracking. Ready to stream real-time diagnostic performance data into core cloud execution and facility orchestration systems.\n                </p>\n              </div>\n            </div>\n          </div>\n        )}\n\n        {/* VIEW TWO: LIVE ROBUST EFFICIENCY SIMULATOR MATRIX */}\n        {activeTab === 'sim' && (\n          <div className=\"space-y-8 animate-fadeIn\">\n            <div className=\"border-b border-slate-800 pb-4\">\n              <h2 className=\"text-2xl font-extrabold text-white tracking-tight\">KITES Advanced Efficiency Calculator</h2>\n              <p className=\"text-sm text-slate-400\">A high-fidelity tool showcasing exact energy mitigation curves when transitioning multi-tier kitchens from obsolete gas lines to induction setups.</p>\n            </div>\n\n            <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-8\">\n              {/* USER INPUT CONFIGURATION INTERFACE */}\n              <div className=\"bg-slate-900 p-6 rounded-2xl border border-slate-800 space-y-6 flex flex-col justify-between\">\n                <div>\n                  <h3 className=\"text-sm font-mono font-bold tracking-widest text-slate-400 uppercase mb-4 flex items-center gap-2\">\n                    <Cpu className=\"w-4 h-4 text-cyan-400\" /> Input Parameters\n                  </h3>\n                  \n                  <div className=\"space-y-5\">\n                    <div>\n                      <div className=\"flex justify-between text-xs font-medium mb-2\">\n                        <span className=\"text-slate-300\">Active Combustion Cook Burners</span>\n                        <span className=\"text-cyan-400 font-mono font-bold\">{gasStoveCount} Station Blocks</span>\n                      </div>\n                      <input \n                        type=\"range\" \n                        min=\"2\" \n                        max=\"24\" \n                        value={gasStoveCount} \n                        onChange={(e) => setGasStoveCount(parseInt(e.target.value))}\n                        className=\"w-full accent-cyan-500 h-1.5 bg-slate-800 rounded-lg appearance-none cursor-pointer\"\n                      />\n                    </div>\n\n                    <div>\n                      <div className=\"flex justify-between text-xs font-medium mb-2\">\n                        <span className=\"text-slate-300\">Daily Active Peak Usage Timeline</span>\n                        <span className=\"text-cyan-400 font-mono font-bold\">{operatingHours} Hours / Day</span>\n                      </div>\n                      <input \n                        type=\"range\" \n                        min=\"4\" \n                        max=\"24\" \n                        value={operatingHours} \n                        onChange={(e) => setOperatingHours(parseInt(e.target.value))}\n                        className=\"w-full accent-cyan-500 h-1.5 bg-slate-800 rounded-lg appearance-none cursor-pointer\"\n                      />\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"bg-slate-950 p-4 rounded-xl border border-slate-800 text-xs text-slate-400 space-y-2 mt-4 font-mono\">\n                  <p className=\"text-white font-semibold\">Mathematical Modeling Constants:</p>\n                  <p>• Baseline Gas Fuel Efficiency Factor: ~40%</p>\n                  <p>• KITES Smart Core System Efficiency Factor: ~91%</p>\n                  <p>• Extrapolated Carbon Footprint Mitigation Index: 2.8kg/hr per stack</p>\n                </div>\n              </div>\n\n              {/* SIMULATED METRIC TELEMETRY INTERFACE FOR INVESTORS */}\n              <div className=\"lg:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-6\">\n                <div className=\"bg-gradient-to-br from-slate-900 to-cyan-950/40 p-6 rounded-2xl border border-slate-800 flex flex-col justify-between relative overflow-hidden group\">\n                  <div className=\"absolute top-0 right-0 p-4 text-cyan-500/10 transition-transform group-hover:scale-110\">\n                    <TrendingUp className=\"w-32 h-32 stroke-[1]\" />\n                  </div>\n                  <div className=\"relative\">\n                    <span className=\"text-xs font-mono font-bold uppercase tracking-widest text-cyan-400\">Projected OpEx Savings</span>\n                    <h4 className=\"text-5xl font-black text-white tracking-tight mt-2 font-mono\">\n                      ${dynamicMonthlySavings.toLocaleString()}\n                      <span className=\"text-sm text-slate-400 font-normal tracking-normal ml-1\">/mo</span>\n                    </h4>\n                  </div>\n                  <p className=\"text-xs text-slate-400 mt-4 leading-relaxed relative\">\n                    Calculated baseline reduction in overhead utility strain across high-throughput commercial configurations. Saves up to 55% over unmitigated natural gas infrastructure.\n                  </p>\n                </div>\n\n                <div className=\"bg-gradient-to-br from-slate-900 to-indigo-950/40 p-6 rounded-2xl border border-slate-800 flex flex-col justify-between relative overflow-hidden group\">\n                  <div className=\"absolute top-0 right-0 p-4 text-indigo-500/10 transition-transform group-hover:scale-110\">\n                    <Flame className=\"w-32 h-32 stroke-[1]\" />\n                  </div>\n                  <div className=\"relative\">\n                    <span className=\"text-xs font-mono font-bold uppercase tracking-widest text-indigo-400\">Carbon Footprint Drop</span>\n                    <h4 className=\"text-5xl font-black text-white tracking-tight mt-2 font-mono\">\n                      {carbonReductionKg.toLocaleString()}\n                      <span className=\"text-sm text-slate-400 font-normal tracking-normal ml-1\"> kg CO₂</span>\n                    </h4>\n                  </div>\n                  <p className=\"text-xs text-slate-400 mt-4 leading-relaxed relative\">\n                    Direct carbon tax exposure reduction and strict compliance mapping alignment for institutional deployment frameworks across green energy metrics.\n                  </p>\n                </div>\n\n                {/* TELEMETRY SIMULATOR PANEL */}\n                <div className=\"sm:col-span-2 bg-slate-900 p-6 rounded-2xl border border-slate-800\">\n                  <div className=\"flex items-center justify-between mb-4\">\n                    <h3 className=\"text-xs font-mono font-bold tracking-widest text-slate-400 uppercase flex items-center gap-2\">\n                      <Thermometer className=\"w-4 h-4 text-emerald-400\" /> Real-Time Smart Pulse Telemetry Mockup Stream\n                    </h3>\n                    <span className=\"px-2 py-0.5 rounded text-[10px] font-mono font-bold bg-emerald-950 text-emerald-400 border border-emerald-800\">\n                      LIVE FEED LOG\n                    </span>\n                  </div>\n                  \n                  <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-4\">\n                    <div className=\"bg-slate-950 p-4 rounded-xl border border-slate-800/60 text-center\">\n                      <span className=\"text-[10px] font-mono text-slate-400 block mb-1 uppercase\">Module Core Temp</span>\n                      <span className=\"text-xl font-bold text-emerald-400 font-mono\">48.2°C</span>\n                    </div>\n                    <div className=\"bg-slate-950 p-4 rounded-xl border border-slate-800/60 text-center\">\n                      <span className=\"text-[10px] font-mono text-slate-400 block mb-1 uppercase\">Inductive Duty Cycles</span>\n                      <span className=\"text-xl font-bold text-white font-mono\">98.6%</span>\n                    </div>\n                    <div className=\"bg-slate-950 p-4 rounded-xl border border-slate-800/60 text-center\">\n                      <span className=\"text-[10px] font-mono text-slate-400 block mb-1 uppercase\">Harmonic Flux Rate</span>\n                      <span className=\"text-xl font-bold text-cyan-400 font-mono\">24.8 kHz</span>\n                    </div>\n                    <div className=\"bg-slate-950 p-4 rounded-xl border border-slate-800/60 text-center\">\n                      <span className=\"text-[10px] font-mono text-slate-400 block mb-1 uppercase\">Target Response lag</span>\n                      <span className=\"text-xl font-bold text-indigo-400 font-mono\">&lt; 0.4s</span>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        )}\n\n        {/* VIEW THREE: ENTERPRISE-GRADE PRODUCT ECOSYSTEM LAYOUT */}\n        {activeTab === 'hardware' && (\n          <div className=\"space-y-8 animate-fadeIn\">\n            <div className=\"border-b border-slate-800 pb-4\">\n              <h2 className=\"text-2xl font-extrabold text-white tracking-tight\">Precision Hardware Portfolio</h2>\n              <p className=\"text-sm text-slate-400\">Review high-capacity configurations engineered explicitly for massive commercial demands and Industry 4.0 infrastructure scalability.</p>\n            </div>\n\n            <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-8\">\n              {/* LEFT SIDEBAR CAPABILITIES FILTER LIST */} \n              <div className=\"space-y-3\">\n                <span className=\"text-[11px] font-mono font-bold tracking-widest text-slate-400 uppercase px-1 block mb-2\">\n                  Select System Variant\n                </span>\n                {PRODUCTS.map((prod) => (\n                  <button\n                    key={prod.id}\n                    onClick={() => setSelectedProduct(prod)}\n                    className={`w-full text-left p-4 rounded-xl transition-all border ${selectedProduct.id === prod.id ? 'bg-cyan-950/30 border-cyan-500/60 text-white shadow-lg' : 'bg-slate-900/60 border-slate-800/80 text-slate-300 hover:bg-slate-900 hover:border-slate-700'}`}\n                  >\n                    <div className=\"flex justify-between items-center\">\n                      <span className=\"font-bold text-sm block\">{prod.name}</span>\n                      <ChevronRight className={`w-4 h-4 transition-transform ${selectedProduct.id === prod.id ? 'text-cyan-400 rotate-90' : 'text-slate-600'}`} />\n                    </div>\n                    <span className=\"text-[10px] font-mono text-slate-400 block mt-1 uppercase tracking-wide\">{prod.category}</span>\n                  </button>\n                ))}\n              </div>\n\n              {/* CENTRAL MAIN DATASHEET GRID VIEW */} \n              <div className=\"lg:col-span-2 bg-slate-900 p-6 md:p-8 rounded-2xl border border-slate-800 space-y-6 flex flex-col justify-between\">\n                <div>\n                  <div className=\"flex justify-between items-start gap-4 flex-wrap border-b border-slate-800 pb-4\">\n                    <div>\n                      <span className=\"text-xs font-mono font-bold uppercase text-cyan-400 bg-cyan-950/50 border border-cyan-800/30 px-2 py-0.5 rounded\">\n                        {selectedProduct.category}\n                      </span>\n                      <h3 className=\"text-2xl font-black text-white tracking-tight mt-2\">{selectedProduct.name}</h3>\n                    </div>\n                  </div>\n\n                  <p className=\"text-slate-300 leading-relaxed text-sm mt-4\">\n                    {selectedProduct.description}\n                  </p>\n                </div>\n\n                {/* HARDWARE TECHNICAL SPECIFICATIONS DATA TABLE GRID */}\n                <div>\n                  <h4 className=\"text-xs font-mono font-bold uppercase tracking-widest text-slate-400 mb-3\">\n                    Technical Baseline Metrics\n                  </h4>\n                  <div className=\"grid grid-cols-2 gap-4\">\n                    <div className=\"bg-slate-950 p-4 rounded-xl border border-slate-800/80\">\n                      <span className=\"text-[10px] font-mono uppercase text-slate-500 block mb-1\">Power Draw Rating</span>\n                      <span className=\"text-sm font-bold text-white font-mono\">{selectedProduct.specs.power}</span>\n                    </div>\n                    <div className=\"bg-slate-950 p-4 rounded-xl border border-slate-800/80\">\n                      <span className=\"text-[10px] font-mono uppercase text-slate-500 block mb-1\">Spatial Envelope Dimensions</span>\n                      <span className=\"text-sm font-bold text-white font-mono\">{selectedProduct.specs.size}</span>\n                    </div>\n                    <div className=\"bg-slate-950 p-4 rounded-xl border border-slate-800/80\">\n                      <span className=\"text-[10px] font-mono uppercase text-slate-500 block mb-1\">Net Structural Weight</span>\n                      <span className=\"text-sm font-bold text-white font-mono\">{selectedProduct.specs.weight}</span>\n                    </div>\n                    <div className=\"bg-slate-950 p-4 rounded-xl border border-slate-800/80\">\n                      <span className=\"text-[10px] font-mono uppercase text-slate-500 block mb-1\">Operational Volume Capacity</span>\n                      <span className=\"text-sm font-bold text-cyan-400 font-mono\">{selectedProduct.specs.capacity}</span>\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"bg-slate-950/60 p-4 rounded-xl border border-slate-800/60 flex items-center justify-between text-xs text-slate-400 font-mono\">\n                  <span className=\"flex items-center gap-1.5 text-[11px]\"><Clock className=\"w-3.5 h-3.5 text-indigo-400\" /> Lead-time SLA: Global distribution configured via rapid custom supply lines</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        )}\n\n      </main>\n\n      {/* --- PREMIUM BRAND FOOTER MATRICES --- */}\n      <footer className=\"bg-slate-950 border-t border-slate-900 mt-20\">\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12\">\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8 text-sm text-slate-400\">\n            \n            <div className=\"space-y-3\">\n              <div className=\"flex items-center gap-2\">\n                <div className=\"p-1.5 bg-cyan-500 text-slate-950 rounded\">\n                  <Zap className=\"w-4 h-4 font-bold\" />\n                </div>\n                <span className=\"text-lg font-bold text-white tracking-tight\">KITES Enterprise</sp